{
  "name": "ash",
  "version": "0.2.0",
  "private": true,
  "description": "Agentic Shell",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "https://github.com/dakdevs/ash.git"
  },
  "workspaces": [
    ".",
    "agent-bridges/anthropic",
    "docs"
  ],
  "engines": {
    "bun": "1.3.14"
  },
  "scripts": {
    "bridge:test": "bun --cwd agent-bridges/anthropic test",
    "changeset": "changeset",
    "docs:build": "bun --cwd docs build",
    "docs:dev": "bun --cwd docs dev",
    "docs:preview": "bun --cwd docs preview",
    "version-packages": "changeset version && bun scripts/sync-cargo-version.mjs && cargo update --workspace",
    "release:tag": "bun scripts/create-release-tag.mjs"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0"
  }
}
